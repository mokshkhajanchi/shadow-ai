# ─── Required ─────────────────────────────────────────────────────
# Get these from https://api.slack.com/apps → Your App → OAuth & Permissions / Basic Information
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Comma-separated Slack user IDs allowed to use the bot (empty = allow all)
ALLOWED_USER_IDS=

# ─── Claude Code ──────────────────────────────────────────────────
# Working directory for Claude Code (where it reads/writes files)
CLAUDE_WORK_DIR=~/Projects

# Model: leave blank for SDK default, or set to claude-sonnet-4-6, claude-opus-4-6, etc.
CLAUDE_MODEL=

# Max conversation turns per session
CLAUDE_MAX_TURNS=30

# Permission mode: acceptEdits (ask before editing) or bypassPermissions (auto-approve all)
CLAUDE_PERMISSION_MODE=acceptEdits

# Thinking mode: off | adaptive | enabled
CLAUDE_THINKING=off
CLAUDE_THINKING_BUDGET=10000

# ─── Limits ───────────────────────────────────────────────────────
# Per-request timeout in seconds
REQUEST_TIMEOUT=600

# Max concurrent Claude Code sessions
MAX_CONCURRENT=5

# Max active sessions (oldest evicted when exceeded)
MAX_ACTIVE_SESSIONS=3

# Session idle timeout in seconds (0 = disabled)
SESSION_IDLE_TIMEOUT=0

# Daily cost limit in USD (0 = unlimited)
DAILY_BUDGET_USD=0

# ─── Knowledge Base ──────────────────────────────────────────────
# Comma-separated paths to docs/code folders for Claude to reference
KNOWLEDGE_PATHS=

# ─── Customization ───────────────────────────────────────────────
# Path to a .md file with custom system prompt additions (org-specific rules, tools, etc.)
SYSTEM_PROMPT_FILE=

# JSON dict mapping repo names to local paths (for PR review + test commands)
# Example: {"avis": "/path/to/avis", "mirage": "/path/to/mirage"}
REPO_PATHS={}

# JSON dict mapping repo names to test commands
# Example: {"avis": {"cmd": "./run.test.sh", "dir": "services/avis"}}
REPO_TEST_CONFIG={}

# ─── Storage ─────────────────────────────────────────────────────
DB_PATH=./shadow_ai.db
LOG_FILE=./bot.log

# ─── Code Intelligence (optional) ────────────────────────────────
# GitNexus MCP availability: auto | on | off
GITNEXUS_ENABLED=auto
