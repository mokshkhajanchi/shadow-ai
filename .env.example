# shadow.ai configuration
# Run `shadow-ai init` to generate this file interactively.

# ─── Identity ─────────────────────────────────────────────────────
BOT_USERNAME=your-name

# ─── Slack (required) ─────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
ALLOWED_USER_IDS=U12345

# ─── Claude Code ──────────────────────────────────────────────────
CLAUDE_WORK_DIR=~/Projects
CLAUDE_PERMISSION_MODE=bypassPermissions
CLAUDE_MAX_TURNS=50
DAILY_BUDGET_USD=500
REQUEST_TIMEOUT=3600

# ─── System Prompt ────────────────────────────────────────────────
SYSTEM_PROMPT_FILE=knowledge/system_prompt.example.md

# ─── MCP Servers ──────────────────────────────────────────────────
# MCP servers are auto-discovered from ~/.claude/settings.json
# Add Jira, Azure DevOps, Sentry, Grafana, GitHub, etc.
# See README.md for setup instructions.

# ─── Knowledge Base ───────────────────────────────────────────────
# Auto-learns from conversations. Add extra paths here:
# KNOWLEDGE_PATHS=/path/to/docs,/path/to/code

# ─── Database & Logging ───────────────────────────────────────────
DB_PATH=./shadow_ai.db
LOG_FILE=./bot.log

# ─── Session Management ──────────────────────────────────────────
# SESSION_IDLE_TIMEOUT=0
# MAX_ACTIVE_SESSIONS=5

# ─── Optional ─────────────────────────────────────────────────────
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_THINKING=off
# CLAUDE_THINKING_BUDGET=10000
# MAX_CONCURRENT=5
# VERBOSE_PROGRESS=false
# CODEBASE_INDEX_MAX_SIZE=50000
# GITNEXUS_ENABLED=auto

# ─── Repo Configuration (JSON) ───────────────────────────────────
# REPO_PATHS={}
# REPO_TEST_CONFIG={}
